# Externally reachable base URL for the UI / API. Set this to EXACTLY how testers
# reach the container in the browser, INCLUDING the port if you publish on
# anything other than 443. It is registered with Keycloak on first boot so login
# works; otherwise you get "Invalid parameter: redirect_uri".
#   https://monitor.example.com        (published on 443)
#   https://192.168.1.50:8453          (published on a custom port)
# Defaults to https://localhost (fine only when browsing from the host itself).
VEXOR_PUBLIC_URL=https://localhost

# Optionally pin the admin username created on first boot. If unset, vexor-setup
# generates one and writes the credentials to /etc/vexor/.initial-admin.
# VEXOR_ADMIN_USER=admin

# Public-demo mode (vexormon.com). When set to 1/true, first boot provisions a
# read-only `demo` / `demo` Keycloak user (vexor-viewer role) and shows the
# credentials as a hint on the login page. Leave UNSET for normal installs --
# you do NOT want a shared demo login on a real deployment.
# VEXOR_DEMO_MODE=1